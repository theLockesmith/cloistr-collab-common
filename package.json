{
  "name": "@cloistr/collab-common",
  "version": "0.1.2",
  "description": "Shared collaboration infrastructure for Cloistr apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./relay": {
      "types": "./dist/relay/index.d.ts",
      "import": "./dist/relay/index.js"
    },
    "./crdt": {
      "types": "./dist/crdt/index.d.ts",
      "import": "./dist/crdt/index.js"
    },
    "./presence": {
      "types": "./dist/presence/index.d.ts",
      "import": "./dist/presence/index.js"
    },
    "./sharing": {
      "types": "./dist/sharing/index.d.ts",
      "import": "./dist/sharing/index.js"
    },
    "./versioning": {
      "types": "./dist/versioning/index.d.ts",
      "import": "./dist/versioning/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext ts,tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@types/libsodium-wrappers": "^0.7.14",
    "lib0": "^0.2.97",
    "libsodium-wrappers": "^0.8.2",
    "nostr-tools": "^2.10.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "keywords": [
    "cloistr",
    "nostr",
    "collaboration",
    "crdt",
    "yjs",
    "e2e-encryption"
  ],
  "author": "Coldforge LLC",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "git@git.coldforge.xyz:coldforge/cloistr-collab-common.git"
  },
  "publishConfig": {
    "@cloistr:registry": "https://git.coldforge.xyz/api/v4/projects/44/packages/npm/"
  }
